<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= post ? "Edit Post" : "New Post" %></title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>

    <%- include("partials/header.ejs") %>

    <main>
        <form class="post-form" action="<%= typeof id !== 'undefined' && id !== null ? '/edit/' + id : '/new' %>" method="POST">
            
            <input 
                type="text" 
                name="title" 
                placeholder="Title" 
                value="<%= post ? post.title : '' %>" 
                required
            >

            <textarea 
                name="content" 
                placeholder="Write your post..." 
                rows="6"
                required
            ><%= post ? post.content : '' %></textarea>

            <button type="submit">
                <%= post ? 'Update' : 'Create' %> Post
            </button>

        </form>
    </main>

    <%- include("partials/footer.ejs") %> 

</body>
</html>